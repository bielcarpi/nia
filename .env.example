# Nia API local demo configuration. Copy to .env for machine-specific overrides.
# The demo adapters are deterministic and require no cloud credentials.
NIA_ENV=local
PORT=8080
NIA_AUTH_MODE=demo
NIA_STORE_MODE=memory
NIA_PROVIDER_MODE=demo
NIA_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8080

# Production identity and persistence (required when their modes are enabled).
NIA_FIREBASE_PROJECT_ID=demo-nia
NIA_REQUIRE_APP_CHECK=false

# Server-owned provider policy. The standard key is server-only and intentionally
# empty in this file. Never expose it through a Flutter --dart-define.
OPENAI_API_KEY=
NIA_OPENAI_BASE_URL=https://api.openai.com/v1
NIA_REALTIME_MODEL=gpt-realtime-2.1
NIA_REALTIME_VOICE=marin
NIA_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
NIA_FEEDBACK_MODEL=gpt-5.6-terra
NIA_REALTIME_SDP_ENDPOINT=https://api.openai.com/v1/realtime/calls
NIA_REALTIME_TTL=10m

# Operational guardrails.
NIA_PROVIDER_TIMEOUT=15s
NIA_REQUEST_TIMEOUT=30s
NIA_MAX_REQUEST_BODY_BYTES=65536
NIA_MAX_CONCURRENT_REQUESTS=64
NIA_SESSION_LIMIT_PER_HOUR=12
NIA_FEEDBACK_LIMIT_PER_HOUR=12
NIA_TURN_LIMIT_PER_MINUTE=120
NIA_LOG_LEVEL=info
